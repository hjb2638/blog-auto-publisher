# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5433/blog_db
DATABASE_URL_SYNC=postgresql://user:password@localhost:5433/blog_db

# LLM (OpenAI-compatible API)
LLM_BASE_URL=
LLM_MODEL=deepseek
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7
LLM_TIMEOUT=120

# WordPress (REQUIRED for publishing)
WP_API_URL=
WP_USERNAME=
WP_APP_PASSWORD=

# Image Search (OPTIONAL - leave empty to skip)
UNSPLASH_ACCESS_KEY=
PEXELS_API_KEY=

# Application
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DEBUG=false
LOG_LEVEL=INFO
